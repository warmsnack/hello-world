<?xml version="1.0"?>
<model>
  <name>turtlebot3_waffle_disturbance</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>

  <author>
    <name>tb3 disturbance sim</name>
    <email>noreply@example.com</email>
  </author>

  <description>
    TurtleBot3 Waffle model tuned for state-estimation research:
    - Gaussian noise injected into the IMU and wheel-encoder odometry.
    - Extremely low wheel friction (mu1/mu2 = 0.05) to force cmd_vel vs. real
      kinematics divergence (wheel slip -> odometry drift).
    - diff_drive publishes wheel odometry on /odom_unfiltered and does NOT
      publish the odom->base_footprint TF (publish_odom_tf = false), so the
      robot_localization EKF owns that transform.
  </description>
</model>
